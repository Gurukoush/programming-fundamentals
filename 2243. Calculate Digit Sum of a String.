

class Solution:
    def digitSum(self, s: str, k: int) -> str:
        while len(s)>k:
            temp = ""
            for i in range(0,len(s),k):
                group = s[i:i+k]

                sum = 0
                for ch in group:
                    sum+=int(ch)

                temp+=str(sum)

            s = temp

        return s 
